---
# Exemplos de variaveis SENSIVEIS. Copie para vault.yml, criptografe e NUNCA
# versione o vault.yml:
#   cp vault.yml.example vault.yml
#   ansible-vault encrypt vault.yml
#   ansible-playbook ... --ask-vault-pass
# No AWX, cadastre como Vault Credential.
#
# Credenciais de conexao (chave SSH do Linux, usuario/senha WinRM do Windows)
# NAO ficam aqui - vao na Machine Credential do AWX.

# Exemplo: PSK do Zabbix Agent (so e usado se voce habilitar TLS na role:
# zabbix_agent_tls_enabled=true). Gere a PSK com: openssl rand -hex 32
vault_zabbix_agent_psk_identity: "PSK-AGENT-POC"
vault_zabbix_agent_psk: "REPLACE_WITH_64_HEX_CHARS"
