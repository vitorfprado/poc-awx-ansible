---
# Inventario da POC. Copie para hosts.yml e preencha os IPs privados das EC2s
# (outputs do Terraform). Conter APENAS dados nao sensiveis (nome + IP).
# Usuario/senha/chave NAO ficam aqui - vao na Machine Credential do AWX.
all:
  children:
    proxy:
      hosts:
        proxy-01:
          ansible_host: "<PROXY_PRIVATE_IP>" # output: zabbix_proxy_private_ip

    linux:
      hosts:
        linux-01:
          ansible_host: "<LINUX_PRIVATE_IP>" # output: zabbix_agent_private_ips
