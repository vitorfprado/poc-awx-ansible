###############################################################################
# Exemplo de configuracao da POC awx-zabbix-poc.
# Copie para terraform.tfvars e ajuste os valores.
###############################################################################

# --- Identificacao -----------------------------------------------------------
project_name = "awx-zabbix-poc"
environment  = "poc"
aws_region   = "us-east-1"

tags = {
  Owner = "vitorfprado"
  Poc   = "awx-zabbix"
}

# --- Rede --------------------------------------------------------------------
vpc_cidr             = "10.0.0.0/16"
public_subnet_cidrs  = ["10.0.0.0/20", "10.0.16.0/20"]
private_subnet_cidrs = ["10.0.48.0/20", "10.0.64.0/20"]
# azs                = ["us-east-1a", "us-east-1b"] # opcional; vazio = automatico
single_nat_gateway = true

# --- EKS (AWX) ---------------------------------------------------------------
cluster_version         = "1.32"
eks_node_instance_types = ["t3.large"]
eks_node_desired_size   = 2
eks_node_min_size       = 1
eks_node_max_size       = 3

eks_endpoint_public_access = true
# Restrinja ao seu IP em vez de 0.0.0.0/0 sempre que possivel:
eks_public_access_cidrs = ["0.0.0.0/0"]

# Principals IAM com admin no cluster (para kubectl fora do pipeline).
# Gerenciado por apply/destroy. Ex.: seu usuario IAM.
eks_admin_principal_arns = ["arn:aws:iam::650687537445:user/vitor.prado"]

# --- EC2s Zabbix -------------------------------------------------------------
# Nome de um key pair EC2 ja existente na regiao (Proxy + agents Linux).
# Use null/comente para acesso somente via SSM Session Manager.
ssh_key_name = "poc-ansible"

proxy_instance_type = "t3.micro"
agent_instance_type = "t3.micro"
agent_count         = 1 # agents Linux

# --- Conectividade Zabbix ----------------------------------------------------
zabbix_server_address = "zabbix.exemplo.interno" # IP ou hostname do Server central
zabbix_server_cidr    = "10.10.0.0/16"           # null = sem regra de egress dedicada
zabbix_proxy_port     = 10051
zabbix_agent_port     = 10050
