<powershell>
# user_data da EC2 Windows: define a senha do Administrator e habilita o WinRM
# (HTTPS, cert self-signed) para o Ansible/AWX conectar. NAO instala o Zabbix
# (isso e feito depois pela role Ansible zabbix_agent_windows).
$ErrorActionPreference = "Stop"

# 1) Senha do Administrator (usada pela Machine Credential do AWX).
$pwd   = ConvertTo-SecureString '${admin_password}' -AsPlainText -Force
$admin = Get-LocalUser -Name 'Administrator'
$admin | Set-LocalUser -Password $pwd
$admin | Enable-LocalUser

# 2) WinRM para o Ansible: listener HTTPS (5986) com cert self-signed + basic auth.
winrm quickconfig -quiet
$cert     = New-SelfSignedCertificate -DnsName $env:COMPUTERNAME -CertStoreLocation 'Cert:\LocalMachine\My'
$listener = "@{Hostname=`"$env:COMPUTERNAME`";CertificateThumbprint=`"$($cert.Thumbprint)`"}"
cmd /c "winrm create winrm/config/Listener?Address=*+Transport=HTTPS $listener"
winrm set winrm/config/service/auth '@{Basic="true"}'
winrm set winrm/config/service '@{AllowUnencrypted="false"}'

# 3) Firewall: libera o WinRM HTTPS (a rede privada/SG ja restringe a origem).
New-NetFirewallRule -DisplayName 'WinRM HTTPS (Ansible)' -Direction Inbound -Protocol TCP -LocalPort 5986 -Action Allow -ErrorAction SilentlyContinue
</powershell>
